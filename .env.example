# Configuration Firebase
# Remplacez ces valeurs par celles de votre projet Firebase
# Firebase Console > Paramètres du projet > Applications web > SDK Firebase
VITE_FIREBASE_API_KEY=VOTRE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=VOTRE_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://VOTRE_PROJECT_ID-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=VOTRE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=VOTRE_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Token Vercel pour le déploiement automatique (depuis deploy-vercel.js)
VERCEL_TOKEN=votre_token_vercel
